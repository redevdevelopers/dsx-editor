{
  "name": "dsx-editor",
  "version": "6.0.0",
  "description": "A rhythm game chart editor for DreamSyncX.",
  "main": "main.js",
  "scripts": {
    "test": "jest",
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "Kyrin Hiron",
  "license": "MIT",
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/pixi.js": "^5.0.0",
    "electron": "^31.2.1",
    "electron-builder": "^25.0.0",
    "jest": "^30.2.0"
  },
  "build": {
    "appId": "com.kynix.dsx.editor",
    "productName": "DreamSync Studio 6",
    "artifactName": "DreamSync-Studio-6-Setup-${version}.${ext}",
    "copyright": "Copyright © 2026 Redevon Community. All rights reserved.",
    "publish": [
      {
        "provider": "github",
        "owner": "redevdevelopers",
        "repo": "dsx-editor",
        "releaseType": "release"
      }
    ],
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/*.map",
      "!**/.*",
      "!README.md",
      "!RELEASE_NOTES.md",
      "!CODE_SIGNING_GUIDE.md",
      "!build_commands.txt"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon/dsxicon256.ico",
      "publisherName": "Redevon Developers",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "installerIcon": "assets/icon/dsxicon256.ico",
      "uninstallerIcon": "assets/icon/dsxicon256.ico"
    }
  }
}
